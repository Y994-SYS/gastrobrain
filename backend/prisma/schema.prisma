generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// TENANT (FİRMA)
// ─────────────────────────────────────────

model Tenant {
  id          Int       @id @default(autoincrement())
  ad          String
  slug        String    @unique
  email       String    @unique
  telefon     String?
  aktif       Boolean   @default(true)
  plan        Plan      @default(BASLANGIC)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lisansBitis DateTime?
  lisansNot   String?

  kullanicilar  Kullanici[]
  subeler       Sube[]
  kategoriler   Kategori[]
  olcuBirimleri OlcuBirimi[]
  stokKartlari  StokKart[]
  receteler     Recete[]
  cariKartlar   CariKart[]
  personeller   Personel[]
  auditLoglar   AuditLog[]
  odemeBildirimleri OdemeBildirimi[]
}

enum Plan {
  BASLANGIC
  PROFESYONEL
  KURUMSAL
}

// ─────────────────────────────────────────
// KULLANICI & YETKİ
// ─────────────────────────────────────────

model Kullanici {
  id        Int      @id @default(autoincrement())
  ad        String
  email     String
  sifre     String
  rol       Rol      @default(PERSONEL)
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  tenantId Int?

  sube   Sube? @relation(fields: [subeId], references: [id])
  subeId Int?

  @@unique([email, tenantId])
  @@index([tenantId])

  auditLoglar AuditLog[]
}

enum Rol {
  SUPER_ADMIN
  TENANT_ADMIN
  ADMIN
  MUDUR
  DEPO
  KASA
  PERSONEL
}

model SifreToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  email     String
  tenantId  Int?
  kullanildi Boolean @default(false)
  sonTarih  DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

// ─────────────────────────────────────────
// ŞUBE
// ─────────────────────────────────────────

model Sube {
  id        Int      @id @default(autoincrement())
  ad        String
  adres     String?
  telefon   String?
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int

  kullanicilar    Kullanici[]
  stokHareketleri StokHareket[]
  satislar        Satis[]
  personeller     Personel[]

  @@index([tenantId])
}

// ─────────────────────────────────────────
// STOK
// ─────────────────────────────────────────

model Kategori {
  id   Int     @id @default(autoincrement())
  ad   String
  renk String?

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int

  stokKartlari StokKart[]

  @@unique([ad, tenantId])
  @@index([tenantId])
}

model OlcuBirimi {
  id       Int    @id @default(autoincrement())
  ad       String
  kisaltma String

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int

  stokKartlari StokKart[]

  @@unique([ad, tenantId])
  @@unique([kisaltma, tenantId])
  @@index([tenantId])
}

model StokKart {
  id        Int      @id @default(autoincrement())
  kod       String
  ad        String
  aciklama  String?
  minStok   Float    @default(0)
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int

  kategori   Kategori   @relation(fields: [kategoriId], references: [id])
  kategoriId Int
  birim      OlcuBirimi @relation(fields: [birimId], references: [id])
  birimId    Int

  stokHareketleri      StokHareket[]
  receteKalemleri      ReceteKalem[]
  cariHareketKalemleri CariHareketKalem[]

  @@unique([kod, tenantId])
  @@index([tenantId])
  @@index([kategoriId])
}

model StokHareket {
  id         Int            @id @default(autoincrement())
  tip        StokHareketTip
  miktar     Float
  birimFiyat Float?
  aciklama   String?
  tarih      DateTime       @default(now())
  createdAt  DateTime       @default(now())

  stokKart   StokKart @relation(fields: [stokKartId], references: [id])
  stokKartId Int
  sube       Sube     @relation(fields: [subeId], references: [id])
  subeId     Int

  cariHareket   CariHareket? @relation(fields: [cariHareketId], references: [id])
  cariHareketId Int?
  satis         Satis?       @relation(fields: [satisId], references: [id])
  satisId       Int?

  @@index([stokKartId])
  @@index([subeId])
  @@index([tarih])
  @@index([tip])
}

enum StokHareketTip {
  GIRIS_FATURA
  IADE_FATURA
  SATIS
  ZAYI
  TUKETIM
  AY_SONU_SAYIM
  SUBE_TRANSFER_IN
  SUBE_TRANSFER_OUT
}

// ─────────────────────────────────────────
// REÇETE
// ─────────────────────────────────────────

model Recete {
  id          Int      @id @default(autoincrement())
  ad          String
  aciklama    String?
  satisKodu   String?
  satisFiyati Float?
  aktif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  porsiyonSayisi  Int?
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int

  kalemler ReceteKalem[]
  satislar Satis[]

  @@unique([satisKodu, tenantId])
  @@index([tenantId])
}

model ReceteKalem {
  id     Int   @id @default(autoincrement())
  miktar Float
  carpan Float @default(1)
  bolen  Float @default(1)

  recete     Recete   @relation(fields: [receteId], references: [id])
  receteId   Int
  stokKart   StokKart @relation(fields: [stokKartId], references: [id])
  stokKartId Int

  @@index([receteId])
  @@index([stokKartId])
}

// ─────────────────────────────────────────
// SATIŞ
// ─────────────────────────────────────────

model Satis {
  id         Int      @id @default(autoincrement())
  adet       Float
  birimFiyat Float
  toplam     Float
  tarih      DateTime @default(now())
  aciklama   String?
  createdAt  DateTime @default(now())

  recete   Recete @relation(fields: [receteId], references: [id])
  receteId Int
  sube     Sube   @relation(fields: [subeId], references: [id])
  subeId   Int

  stokHareketleri StokHareket[]

  @@index([subeId])
  @@index([tarih])
  @@index([receteId])
}

// ─────────────────────────────────────────
// CARİ HESAP
// ─────────────────────────────────────────

model CariKart {
  id        Int      @id @default(autoincrement())
  kod       String
  ad        String
  vergiNo   String?
  telefon   String?
  email     String?
  adres     String?
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int

  hareketler CariHareket[]

  @@unique([kod, tenantId])
  @@index([tenantId])
}

model CariHareket {
  id        Int            @id @default(autoincrement())
  tip       CariHareketTip
  tutar     Float
  aciklama  String?
  belgeNo   String?
  tarih     DateTime       @default(now())
  createdAt DateTime       @default(now())

  cariKart   CariKart @relation(fields: [cariKartId], references: [id])
  cariKartId Int

  kalemler        CariHareketKalem[]
  stokHareketleri StokHareket[]

  @@index([cariKartId])
  @@index([tarih])
}

enum CariHareketTip {
  BORC
  ALACAK
  ODEME
  TAHSILAT
}

model CariHareketKalem {
  id         Int   @id @default(autoincrement())
  miktar     Float
  birimFiyat Float
  toplam     Float

  cariHareket   CariHareket @relation(fields: [cariHareketId], references: [id])
  cariHareketId Int
  stokKart      StokKart    @relation(fields: [stokKartId], references: [id])
  stokKartId    Int

  @@index([cariHareketId])
}

// ─────────────────────────────────────────
// PERSONEL
// ─────────────────────────────────────────

model Personel {
  id              Int      @id @default(autoincrement())
  ad              String
  soyad           String
  telefon         String?
  tcKimlik        String?
  baslangicTarihi DateTime
  maas            Float
  aktif           Boolean  @default(true)
  createdAt       DateTime @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int

  sube   Sube @relation(fields: [subeId], references: [id])
  subeId Int

  maaslar  PersonelMaas[]
  avanslar PersonelAvans[]
  devamlar PersonelDevam[]

  @@unique([tcKimlik, tenantId])
  @@index([tenantId])
  @@index([subeId])
}

model PersonelMaas {
  id     Int      @id @default(autoincrement())
  yil    Int
  ay     Int
  tutar  Float
  odendi Boolean  @default(false)
  tarih  DateTime @default(now())

  personel   Personel @relation(fields: [personelId], references: [id])
  personelId Int

  @@index([personelId])
}

model PersonelAvans {
  id       Int      @id @default(autoincrement())
  tutar    Float
  aciklama String?
  tarih    DateTime @default(now())

  personel   Personel @relation(fields: [personelId], references: [id])
  personelId Int

  @@index([personelId])
}

model PersonelDevam {
  id       Int        @id @default(autoincrement())
  tarih    DateTime
  durum    DevamDurum
  mesai    Float?
  aciklama String?

  personel   Personel @relation(fields: [personelId], references: [id])
  personelId Int

  @@index([personelId])
  @@index([tarih])
}

enum DevamDurum {
  CALISTI
  IZIN
  RAPOR
  DEVAMSIZ
}

// ─────────────────────────────────────────
// AUDİT LOG
// ─────────────────────────────────────────

model AuditLog {
  id        Int      @id @default(autoincrement())
  eylem     String   // SATIS_EKLE, STOK_GIRIS, KULLANICI_SIL vs.
  detay     String?  // JSON string — ne değişti
  ip        String?
  createdAt DateTime @default(now())

  kullanici   Kullanici? @relation(fields: [kullaniciId], references: [id])
  kullaniciId Int?

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int

  @@index([tenantId])
  @@index([kullaniciId])
  @@index([createdAt])
}

// ─────────────────────────────────────────
// ÖDEME BİLDİRİMİ — YENİ
// ─────────────────────────────────────────

model OdemeBildirimi {
  id            Int        @id @default(autoincrement())
  plan          String     // 'baslangic' | 'profesyonel' | 'kurumsal'
  periyot       String     // 'aylik' | 'yillik'
  tutar         Float
  not           String?
  durum         OdemeDurum @default(BEKLIYOR)
  redNotu       String?
  createdAt     DateTime   @default(now())
  islenmeTarihi DateTime?

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int

  @@index([tenantId])
  @@index([durum])
}

enum OdemeDurum {
  BEKLIYOR
  ONAYLANDI
  REDDEDILDI
}
